# Nadura V2 client Supabase (project utczdtqqawncwuwnfzig) — the live data source.
# Injected server-side by the Vite proxy (/nadura). Never shipped to the browser.
# RLS on this project locks out the anon/publishable key, so reads use the
# service key (service_role) injected by the proxy — exactly like the NFG build.
VITE_NADURA_SUPABASE_URL=https://utczdtqqawncwuwnfzig.supabase.co
VITE_NADURA_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Before going live (client-facing) ────────────────────────────
# This dev setup uses the service key server-side via the proxy (fine for
# internal/staging). For production exposure either:
#   1. Enable Row Level Security policies that let a per-solution anon key read
#      only Nadura's rows, OR
#   2. Give Nadura its own read-only Supabase role / dedicated project.
# Keep the fetch path proxied — never move the key into client-visible JS.
